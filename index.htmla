<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Maintenance Mode</title>

  <!-- FONT -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    html,
    body{
      width:100%;
      min-height:100%;
      overflow-x:hidden;
    }

    body{
      font-family:'Inter',sans-serif;

      background:#050816;
      color:white;

      position:relative;

      display:flex;
      justify-content:center;
      align-items:center;

      padding:20px;

      overflow-y:auto;

      -webkit-overflow-scrolling:touch;
    }

    /* PARTICLES */

    #particles-js{
      position:fixed;
      inset:0;
      z-index:0;

      background:#050816;
    }

    .bg-overlay{
      position:fixed;
      inset:0;

      background:
      radial-gradient(circle at top left,
      rgba(45,212,191,0.12),
      transparent 30%),

      radial-gradient(circle at bottom right,
      rgba(96,165,250,0.10),
      transparent 30%);

      pointer-events:none;

      z-index:1;
    }

    /* CONTAINER */

    .container{
      position:relative;
      z-index:2;

      width:100%;
      max-width:720px;

      display:flex;
      justify-content:center;
      align-items:center;

      min-height:100dvh;

      padding:20px 0;
    }

    /* CARD */

    .card{
      width:100%;

      background:
      rgba(255,255,255,0.05);

      border:
      1px solid rgba(255,255,255,0.08);

      backdrop-filter:blur(18px);

      border-radius:32px;

      padding:50px 40px;

      position:relative;

      overflow:hidden;

      box-shadow:
      0 20px 80px rgba(0,0,0,0.45);
    }

    .card::before{
      content:"";

      position:absolute;
      inset:0;

      border-radius:inherit;

      padding:1px;

      background:
      linear-gradient(
        135deg,
        rgba(45,212,191,0.5),
        rgba(255,255,255,0.05)
      );

      -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);

      -webkit-mask-composite:xor;
      mask-composite:exclude;

      pointer-events:none;
    }

    /* BADGE */

    .badge{
      display:inline-flex;
      align-items:center;
      gap:10px;

      padding:12px 20px;

      border-radius:999px;

      background:
      rgba(45,212,191,0.12);

      border:
      1px solid rgba(45,212,191,0.25);

      color:#5eead4;

      font-size:14px;
      font-weight:600;

      margin-bottom:30px;
    }

    .pulse{
      width:10px;
      height:10px;

      background:#2dd4bf;

      border-radius:50%;

      position:relative;
    }

    .pulse::after{
      content:"";

      position:absolute;
      inset:0;

      border-radius:50%;

      background:#2dd4bf;

      animation:pulse 1.8s infinite;
    }

    @keyframes pulse{

      0%{
        transform:scale(1);
        opacity:1;
      }

      100%{
        transform:scale(3.5);
        opacity:0;
      }
    }

    /* ICON */

    .icon-box{
      width:120px;
      height:120px;

      margin:0 auto 30px;

      border-radius:30px;

      display:flex;
      justify-content:center;
      align-items:center;

      background:
      linear-gradient(
        135deg,
        rgba(45,212,191,0.18),
        rgba(96,165,250,0.08)
      );

      border:
      1px solid rgba(255,255,255,0.08);

      box-shadow:
      inset 0 0 40px rgba(45,212,191,0.12);
    }

    .icon{
      font-size:58px;
    }

    /* TITLE */

    .animated-title{
      font-size:clamp(38px,6vw,62px);

      font-weight:800;

      line-height:1.1;

      letter-spacing:-2px;

      margin-bottom:18px;

      text-align:center;

      background:
      linear-gradient(
        90deg,
        #ffffff,
        #5eead4,
        #60a5fa,
        #c084fc,
        #ffffff
      );

      background-size:300% auto;

      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;

      animation:textGradient 6s linear infinite;
    }

    @keyframes textGradient{

      0%{
        background-position:0% center;
      }

      100%{
        background-position:300% center;
      }
    }

    /* DESCRIPTION */

    p{
      color:rgba(255,255,255,0.72);

      font-size:17px;

      line-height:1.8;

      text-align:center;

      max-width:580px;

      margin:0 auto;
    }

    /* STATUS */

    .status-box{
      margin-top:35px;

      display:grid;

      grid-template-columns:
      repeat(auto-fit,minmax(180px,1fr));

      gap:18px;
    }

    .status-item{
      background:
      rgba(255,255,255,0.04);

      border:
      1px solid rgba(255,255,255,0.08);

      border-radius:24px;

      padding:24px;
    }

    .status-label{
      color:rgba(255,255,255,0.5);

      font-size:13px;

      margin-bottom:10px;
    }

    .status-value{
      font-size:20px;
      font-weight:700;
    }

    /* FOOTER */

    .footer{
      margin-top:35px;

      text-align:center;

      color:rgba(255,255,255,0.45);

      font-size:14px;
    }

    .dots{
      display:inline-flex;
      gap:6px;

      margin-left:8px;
    }

    .dots span{
      width:6px;
      height:6px;

      border-radius:50%;

      background:#5eead4;

      animation:blink 1.4s infinite;
    }

    .dots span:nth-child(2){
      animation-delay:.2s;
    }

    .dots span:nth-child(3){
      animation-delay:.4s;
    }

    @keyframes blink{

      0%,80%,100%{
        opacity:.2;
        transform:translateY(0);
      }

      40%{
        opacity:1;
        transform:translateY(-4px);
      }
    }

    /* MOBILE */

    @media(max-width:640px){

      body{
        align-items:flex-start;
      }

      .container{
        min-height:auto;
        padding:20px 0 40px;
      }

      .card{
        padding:34px 22px;
        border-radius:28px;
      }

      .icon-box{
        width:100px;
        height:100px;
      }

      .icon{
        font-size:48px;
      }

      p{
        font-size:15px;
      }

      .status-box{
        grid-template-columns:1fr;
      }
    }

  </style>
</head>

<body>

  <!-- PARTICLES -->
  <div id="particles-js"></div>

  <!-- OVERLAY -->
  <div class="bg-overlay"></div>

  <!-- CONTENT -->
  <div class="container">

    <div class="card">

      <!-- BADGE -->
      <div class="badge">
        <div class="pulse"></div>
        Maintenance Mode Active
      </div>

      <!-- ICON -->
      <div class="icon-box">
        <div class="icon">🛠️</div>
      </div>

      <!-- TITLE -->
      <h1 class="animated-title">
        Sistem Sedang Maintenance
      </h1>

      <!-- DESCRIPTION -->
      <p>
        Kami sedang melakukan pembaruan sistem untuk meningkatkan performa,
        keamanan, dan stabilitas aplikasi. Silakan kembali beberapa saat lagi.
      </p>

      <!-- STATUS -->
      <div class="status-box">

        <div class="status-item">
          <div class="status-label">
            Status Server
          </div>

          <div class="status-value">
            Maintenance
          </div>
        </div>

        <div class="status-item">
          <div class="status-label">
            Estimasi Selesai
          </div>

          <div class="status-value" id="countdown">
            Menghitung...
          </div>
        </div>

        <div class="status-item">
          <div class="status-label">
            Versi Update
          </div>

          <div class="status-value">
            v2.6.0
          </div>
        </div>

      </div>

      <!-- FOOTER -->
      <div class="footer">
        Harap tunggu, sistem sedang dipersiapkan kembali

        <span class="dots">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </div>

    </div>

  </div>

  <!-- PARTICLES JS -->
  <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>

  <script>

    /* =========================
       SET WAKTU SELESAI
    ========================= */

    const endDate =
      new Date('2026-05-13T20:00:00')

    /* =========================
       PARTICLES
    ========================= */

    particlesJS('particles-js', {

      particles: {

        number: {
          value: 70
        },

        color: {
          value: '#5eead4'
        },

        shape: {
          type: 'circle'
        },

        opacity: {
          value: 0.5
        },

        size: {
          value: 3
        },

        move: {
          enable: true,
          speed: 1.2
        },

        line_linked: {
          enable: true,
          distance: 150,
          color: '#5eead4',
          opacity: 0.15,
          width: 1
        }
      },

      interactivity: {

        detect_on: 'canvas',

        events: {

          onhover: {
            enable: true,
            mode: 'grab'
          },

          resize: true
        }
      },

      retina_detect: true
    })

    /* =========================
       COUNTDOWN
    ========================= */

    function updateCountdown(){

      const now = new Date()

      const diff = endDate - now

      const countdown =
      document.getElementById('countdown')

      if(diff <= 0){

        countdown.innerHTML =
        'Maintenance Selesai'

        return
      }

      const days =
      Math.floor(
        diff / (1000 * 60 * 60 * 24)
      )

      const hours =
      Math.floor(
        (diff / (1000 * 60 * 60)) % 24
      )

      const minutes =
      Math.floor(
        (diff / (1000 * 60)) % 60
      )

      const seconds =
      Math.floor(
        (diff / 1000) % 60
      )

      let text = ''

      if(days > 0){
        text += `${days} Hari `
      }

      if(hours > 0 || days > 0){
        text += `${hours} Jam `
      }

      text += `${minutes} Menit ${seconds} Detik`

      countdown.innerHTML = text
    }

    updateCountdown()

    setInterval(updateCountdown, 1000)

  </script>

</body>
</html>
